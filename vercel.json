{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "/robots.txt"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api.js"
    },
    {
      "source": "/smsuser/(.*)",
      "destination": "/smsuser/$1.html"
    },
    {
      "source": "/smsadmin/(.*)",
      "destination": "/smsadmin/$1.html"
    }
  ]
}